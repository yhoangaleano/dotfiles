[user]
	name = TU_NOMBRE
	email = TU_EMAIL_PERSONAL

# Para múltiples cuentas por carpeta, descomentá y ajustá:
# [includeIf "gitdir:~/projects/EMPRESA/"]
# 	path = ~/.gitconfig-empresa

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
	theme = Dracula

[merge]
	conflictstyle = diff3

[diff]
	colorMoved = default
